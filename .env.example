# Copy to .env for local development.

# HTTP port the service listens on.
PORT=3000

# Node environment.
NODE_ENV=development

# PostgreSQL connection (matches docker-compose.yml defaults).
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=ledger
DB_PASSWORD=ledger
DB_NAME=ledger_core

# On managed hosts (Railway, Render, Fly) set a single connection URL instead
# of the DB_* vars above. When present it takes priority.
# DATABASE_URL=postgres://user:password@host:5432/dbname

# Set to true when the managed Postgres requires TLS.
DB_SSL=false

# Set to true to log every SQL statement.
DB_LOGGING=false
