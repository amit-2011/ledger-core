# Copy to .env for local development.

# HTTP port the service listens on.
PORT=3000

# Node environment.
NODE_ENV=development

# PostgreSQL connection (matches docker-compose.yml defaults).
DB_HOST=localhost
DB_PORT=5432
DB_USERNAME=ledger
DB_PASSWORD=ledger
DB_NAME=ledger_core

# Set to true to log every SQL statement.
DB_LOGGING=false
